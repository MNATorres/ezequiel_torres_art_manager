# Backend REST API the manager talks to.
VITE_API_BASE_URL=http://localhost:3000

# Public site URL, used by the "Ver el sitio" / "Ver en el sitio" preview links.
VITE_PUBLIC_SITE_URL=https://your-public-site.vercel.app

# Firebase project config for Google sign-in (Firebase Console > Project
# Settings > General > Your apps > Web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
